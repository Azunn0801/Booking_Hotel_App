<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AndroidApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#0073BB</item>
        <item name="colorPrimaryVariant">#005A9E</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:statusBarColor">#0073BB</item>
    </style>

    <style name="RoundedCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="RoundedCornersLarge">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="RoundedCornersSmall">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="RoundedCornersImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="FilterChipStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:background">@drawable/bg_filter_chip</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:layout_marginEnd">8dp</item>
    </style>

    <style name="FilterTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="FilterIconStyle">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="tint">#666666</item>
    </style>

    <style name="FilterArrowStyle">
        <item name="android:layout_width">16dp</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="tint">#999999</item>
    </style>
</resources>