<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@android:color/white">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/shimmerImage"
        android:layout_width="110dp"
        android:layout_height="130dp"
        android:background="#F2F2F2"
        app:shapeAppearanceOverlay="@style/RoundedCornersLarge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/shimmerTitle1"
        android:layout_width="180dp"
        android:layout_height="16dp"
        android:layout_marginStart="16dp"
        android:background="#F2F2F2"
        app:shapeAppearanceOverlay="@style/RoundedCornersSmall"
        app:layout_constraintStart_toEndOf="@id/shimmerImage"
        app:layout_constraintTop_toTopOf="@id/shimmerImage" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/shimmerTitle2"
        android:layout_width="140dp"
        android:layout_height="16dp"
        android:layout_marginTop="10dp"
        android:background="#F2F2F2"
        app:shapeAppearanceOverlay="@style/RoundedCornersSmall"
        app:layout_constraintStart_toStartOf="@id/shimmerTitle1"
        app:layout_constraintTop_toBottomOf="@id/shimmerTitle1" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/shimmerSub"
        android:layout_width="100dp"
        android:layout_height="16dp"
        android:layout_marginTop="10dp"
        android:background="#F2F2F2"
        app:shapeAppearanceOverlay="@style/RoundedCornersSmall"
        app:layout_constraintStart_toStartOf="@id/shimmerTitle1"
        app:layout_constraintTop_toBottomOf="@id/shimmerTitle2" />

    <com.google.android.material.imageview.ShapeableImageView
        android:layout_width="90dp"
        android:layout_height="26dp"
        android:background="#F2F2F2"
        app:shapeAppearanceOverlay="@style/RoundedCornersSmall"
        app:layout_constraintBottom_toBottomOf="@id/shimmerImage"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>